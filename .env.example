# Backend database connection (Neon PostgreSQL)
DB_URL=jdbc:postgresql://<host>.neon.tech/<dbname>?sslmode=require
DB_USERNAME=your_neon_username
DB_PASSWORD=your_neon_password

# CORS allowed origin (React dev server)
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Scheduler poll rate in milliseconds (default 15 min)
SCHEDULER_POLL_RATE_MS=900000
